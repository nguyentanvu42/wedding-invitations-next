# Copy this file to .env.local and fill in values
# Run: vercel env pull .env.local  (after connecting Vercel Postgres)

# Vercel Postgres (auto-filled by vercel env pull)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App settings (add manually)
ADMIN_PASSWORD=your_admin_password_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
